{
  "realm": "enterprise-rag",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "tenant_admin" },
      { "name": "manager" },
      { "name": "employee" },
      { "name": "viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "enterprise-rag-api",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:3002/*"],
      "webOrigins": ["http://localhost:3002"],
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "tenant-acme",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "enterprise-rag-api",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "demo-admin",
      "enabled": true,
      "email": "demo-admin@local.invalid",
      "firstName": "Demo",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "DemoAdmin123!",
          "temporary": false
        }
      ],
      "realmRoles": ["tenant_admin", "manager", "employee", "viewer"]
    },
    {
      "username": "demo-viewer",
      "enabled": true,
      "email": "demo-viewer@local.invalid",
      "firstName": "Demo",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "DemoViewer123!",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
