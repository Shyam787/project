{
  "realm": "enterprise-rag",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "tenant_admin" },
      { "name": "manager" },
      { "name": "employee" },
      { "name": "viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "enterprise-rag-api",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:3002/*"],
      "webOrigins": ["http://localhost:3002"],
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "enterprise-rag-api",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@acme.com",
      "enabled": true,
      "email": "admin@acme.com",
      "firstName": "ACME",
      "lastName": "Admin",
      "attributes": { "tenant_id": ["acme"] },
      "credentials": [
        {
          "type": "password",
          "value": "DemoAdmin123!",
          "temporary": false
        }
      ],
      "realmRoles": ["tenant_admin", "manager", "employee", "viewer"]
    },
    {
      "username": "viewer@acme.com",
      "enabled": true,
      "email": "viewer@acme.com",
      "firstName": "ACME",
      "lastName": "Viewer",
      "attributes": { "tenant_id": ["acme"] },
      "credentials": [
        {
          "type": "password",
          "value": "DemoViewer123!",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    },
    {
      "username": "manager@acme.com",
      "enabled": true,
      "email": "manager@acme.com",
      "firstName": "ACME",
      "lastName": "Manager",
      "attributes": { "tenant_id": ["acme"] },
      "credentials": [
        {
          "type": "password",
          "value": "DemoManager123!",
          "temporary": false
        }
      ],
      "realmRoles": ["manager"]
    },
    {
      "username": "employee@acme.com",
      "enabled": true,
      "email": "employee@acme.com",
      "firstName": "ACME",
      "lastName": "Employee",
      "attributes": { "tenant_id": ["acme"] },
      "credentials": [
        {
          "type": "password",
          "value": "DemoEmployee123!",
          "temporary": false
        }
      ],
      "realmRoles": ["employee"]
    }
  ]
}
