APP_NAME=enterprise-rag
APP_ENV=local
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

POSTGRES_DB=enterprise_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

QDRANT_HOST=qdrant
QDRANT_PORT=6333

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-local-keycloak-password
KEYCLOAK_REALM=enterprise-rag
KEYCLOAK_ISSUER_URL=http://localhost:8081/realms/enterprise-rag
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/enterprise-rag/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=enterprise-rag-api

PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-local-grafana-password

GROQ_API_KEY=replace-with-local-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
